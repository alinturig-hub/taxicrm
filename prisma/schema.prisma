generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  MANAGER
  OPERATOR
}

enum BookingLocationType {
  PICKUP
  DESTINATION
}

enum WebhookProcessingStatus {
  RECEIVED
  PROCESSING
  PROCESSED
  FAILED
  IGNORED
}

enum BookingTimelineSource {
  AUTOCAB
  SYSTEM
  USER
  AI
}

enum WebhookProcessingMode {
  ALWAYS
  WHEN_CONDITIONS_MATCH
}

enum WebhookConditionMode {
  ALL
  ANY
}

enum WebhookConditionOperator {
  EQUALS
  NOT_EQUALS
  CONTAINS
  NOT_CONTAINS
  EXISTS
  NOT_EXISTS
  GREATER_THAN
  GREATER_THAN_OR_EQUALS
  LESS_THAN
  LESS_THAN_OR_EQUALS
  IN
  NOT_IN
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(OPERATOR)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Booking {
  id                String  @id @default(cuid())
  provider          String  @default("AUTOCAB")
  externalId        String
  originalBookingId String?
  bookingType       String?
  typeOfBooking     String?
  status            String  @default("ACTIVE")

  pickupDueTime  DateTime?
  dropOffDueTime DateTime?
  bookedAtTime   DateTime?

  customerName    String?
  telephoneNumber String?
  customerEmail   String?

  paymentType String?
  accountType String?
  accountId   String?
  accountName String?

  companyId           String?
  companyName         String?
  companyRegisteredNo String?
  companyCode         String?

  priority   Int @default(0)
  passengers Int @default(1)
  luggage    Int @default(0)

  driverNote           String?
  officeNote           String?
  ourReference         String?
  flightDetails        String?
  bookedBy             String?
  bookingSource        String?
  cabExchangeReference String?
  loyaltyCardId        String?
  loyaltyCardCostValue Decimal @default(0) @db.Decimal(12, 2)
  isStreetPickup       Boolean @default(false)

  fare                  Decimal? @db.Decimal(12, 2)
  cost                  Decimal? @db.Decimal(12, 2)
  price                 Decimal? @db.Decimal(12, 2)
  extraCost             Decimal? @db.Decimal(12, 2)
  fixedCost             Decimal? @db.Decimal(12, 2)
  fixedPrice            Decimal? @db.Decimal(12, 2)
  chargingAreaCost      Decimal? @db.Decimal(12, 2)
  chargingAreaPrice     Decimal? @db.Decimal(12, 2)
  waitingTime           Decimal? @db.Decimal(12, 2)
  waitingTimeChargeable Decimal? @db.Decimal(12, 2)
  gratuityAmount        Decimal? @db.Decimal(12, 2)
  costSource            String?
  pricingTariff         String?
  pricingSource         String?

  distance            Decimal? @db.Decimal(12, 3)
  systemDistance      Decimal? @db.Decimal(12, 3)
  meterDistance       Decimal? @db.Decimal(12, 3)
  meterDistanceMetres Int?

  gpsMeterDistance     Decimal? @db.Decimal(12, 3)
  gpsMeterPrice        Decimal? @db.Decimal(12, 2)
  gpsMeterPriceSource  String?
  estimatedDistance    Decimal? @db.Decimal(12, 3)
  estimatedPrice       Decimal? @db.Decimal(12, 2)
  estimatedPriceSource String?
  estimatedTime        String?

  capabilities          Json?
  yourReferences        Json?
  promotionCodeDiscount Json?
  rawPayload            Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  locations      BookingLocation[]
  vias           BookingVia[]
  webhookEvents  WebhookEvent[]
  timelineEvents BookingTimelineEvent[]
  snapshots      BookingSnapshot[]

  @@unique([provider, externalId])
  @@index([pickupDueTime])
  @@index([telephoneNumber])
  @@index([customerEmail])
  @@index([status])
}

model BookingLocation {
  id             String              @id @default(cuid())
  bookingId      String
  type           BookingLocationType
  address        String
  zoneId         String?
  zoneDescriptor String?
  zoneName       String?
  longitude      Decimal?            @db.Decimal(11, 8)
  latitude       Decimal?            @db.Decimal(10, 8)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@unique([bookingId, type])
  @@index([zoneId])
}

model BookingVia {
  id             String   @id @default(cuid())
  bookingId      String
  position       Int
  address        String
  zoneId         String?
  zoneDescriptor String?
  zoneName       String?
  longitude      Decimal? @db.Decimal(11, 8)
  latitude       Decimal? @db.Decimal(10, 8)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@unique([bookingId, position])
}

model AutocabWebhookConfiguration {
  id             String                @id @default(cuid())
  displayName    String
  eventType      String                @unique
  endpointSlug   String                @unique
  description    String?
  isEnabled      Boolean               @default(true)
  processingMode WebhookProcessingMode @default(ALWAYS)
  conditionMode  WebhookConditionMode  @default(ALL)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  conditions    WebhookCondition[]
  webhookEvents WebhookEvent[]

  @@index([isEnabled])
  @@index([endpointSlug])
}

model WebhookCondition {
  id              String                   @id @default(cuid())
  configurationId String
  fieldPath       String
  operator        WebhookConditionOperator
  expectedValue   Json?
  position        Int                      @default(0)
  isEnabled       Boolean                  @default(true)
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  configuration AutocabWebhookConfiguration @relation(fields: [configurationId], references: [id], onDelete: Cascade)

  @@index([configurationId, position])
  @@index([fieldPath])
}

model WebhookEvent {
  id                     String                  @id @default(cuid())
  provider               String                  @default("AUTOCAB")
  eventType              String
  externalBookingId      String?
  idempotencyKey         String                  @unique
  status                 WebhookProcessingStatus @default(RECEIVED)
  payload                Json
  headers                Json?
  processingError        String?
  attemptCount           Int                     @default(0)
  receivedAt             DateTime                @default(now())
  processedAt            DateTime?
  updatedAt              DateTime                @updatedAt
  bookingId              String?
  webhookConfigurationId String?

  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  webhookConfiguration AutocabWebhookConfiguration? @relation(fields: [webhookConfigurationId], references: [id], onDelete: SetNull)

  timelineEvents BookingTimelineEvent[]
  snapshots      BookingSnapshot[]

  @@index([provider, eventType])
  @@index([externalBookingId])
  @@index([status])
  @@index([receivedAt])
  @@index([webhookConfigurationId])
}

model BookingTimelineEvent {
  id             String                @id @default(cuid())
  bookingId      String
  webhookEventId String?
  eventType      String
  title          String
  description    String?
  source         BookingTimelineSource @default(AUTOCAB)
  createdBy      String?
  metadata       Json?
  occurredAt     DateTime
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  webhookEvent WebhookEvent? @relation(fields: [webhookEventId], references: [id], onDelete: SetNull)

  @@index([bookingId, occurredAt])
  @@index([eventType])
  @@index([source])
  @@index([webhookEventId])
}

model BookingSnapshot {
  id             String   @id @default(cuid())
  bookingId      String
  webhookEventId String?
  version        Int
  eventType      String
  snapshot       Json
  createdAt      DateTime @default(now())

  booking      Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  webhookEvent WebhookEvent? @relation(fields: [webhookEventId], references: [id], onDelete: SetNull)

  @@unique([bookingId, version])
  @@unique([webhookEventId])
  @@index([bookingId, createdAt])
  @@index([eventType])
}
